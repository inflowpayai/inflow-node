    "@x402/evm": "^2.12.0",
    "@x402/express": "^2.12.0",
    "dotenv": "^16.4.0",
    "express": "^5.0.0",
    "viem": "^2.54.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0"
  }
