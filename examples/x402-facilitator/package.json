{
  "name": "@inflowpayai/example-x402-facilitator",
  "version": "0.0.0",
  "private": true,
  "description": "Example: InFlow facilitator as a drop-in for the foundation — vanilla @x402/express seller + foundation-only EVM buyer.",
  "type": "module",
  "scripts": {
    "dev:seller": "tsx watch src/seller.ts",
    "dev:buyer": "tsx watch src/buyer.ts",
    "start:seller": "tsx src/seller.ts",
    "start:buyer": "tsx src/buyer.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inflowpayai/x402": "workspace:^",
    "@inflowpayai/x402-seller": "workspace:^",
